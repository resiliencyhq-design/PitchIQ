{
  "name": "pitchiq-camera-voice-engine",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "studio": "vite --open /studio/",
    "build": "vite build",
    "test": "node --test tests/*.test.js",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "test:reliability": "npm test && npm run build && npm run test:e2e",
    "ios:add": "npx cap add ios",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "latest",
    "@capacitor/ios": "latest",
    "@puckeditor/core": "latest",
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-moveable": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@capacitor/cli": "latest",
    "@playwright/test": "^1.54.1"
  }
}
