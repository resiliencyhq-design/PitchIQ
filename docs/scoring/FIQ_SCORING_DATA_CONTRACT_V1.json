{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pitchiq.dev/schemas/fiq-scoring-data-contract-v1.json",
  "title": "PitchIQ FIQ Scoring Data Contract v1",
  "type": "object",
  "required": ["playerId", "generatedAt", "scoringVersion", "constructs", "matchMentality"],
  "properties": {
    "playerId": {"type": "string", "minLength": 1},
    "generatedAt": {"type": "string", "format": "date-time"},
    "scoringVersion": {"const": "1.0.0-foundation"},
    "constructs": {
      "type": "object",
      "required": ["awareness", "gameReading", "decisionQuality", "adaptability", "useOfSpace"],
      "properties": {
        "awareness": {"$ref": "#/$defs/constructResult"},
        "gameReading": {"$ref": "#/$defs/constructResult"},
        "decisionQuality": {"$ref": "#/$defs/constructResult"},
        "adaptability": {"$ref": "#/$defs/constructResult"},
        "useOfSpace": {"$ref": "#/$defs/constructResult"}
      },
      "additionalProperties": false
    },
    "integratedFIQ": {
      "oneOf": [
        {"type": "integer", "minimum": 0, "maximum": 100},
        {"type": "null"}
      ]
    },
    "integrationIndicator": {
      "enum": ["transfers-strongly", "transfers-inconsistently", "more-evidence-needed"]
    },
    "matchMentality": {
      "type": "object",
      "required": ["persistence", "recovery", "learning", "composure", "consistency"],
      "properties": {
        "persistence": {"$ref": "#/$defs/mentalityResult"},
        "recovery": {"$ref": "#/$defs/mentalityResult"},
        "learning": {"$ref": "#/$defs/mentalityResult"},
        "composure": {"$ref": "#/$defs/mentalityResult"},
        "consistency": {"$ref": "#/$defs/mentalityResult"}
      },
      "additionalProperties": false
    },
    "strengths": {
      "type": "array",
      "maxItems": 2,
      "items": {"type": "string"}
    },
    "developmentPriorities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": {"type": "string"}
    },
    "recommendedTrainingIds": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    }
  },
  "$defs": {
    "constructResult": {
      "type": "object",
      "required": ["score", "confidence", "evidenceCount", "eligible"],
      "properties": {
        "score": {
          "oneOf": [
            {"type": "integer", "minimum": 0, "maximum": 100},
            {"type": "null"}
          ]
        },
        "confidence": {
          "enum": ["emerging-evidence", "developing-confidence", "strong-confidence"]
        },
        "evidenceCount": {"type": "integer", "minimum": 0},
        "scenarioFamilyCount": {"type": "integer", "minimum": 0},
        "eligible": {"type": "boolean"},
        "lastObservedAt": {
          "oneOf": [
            {"type": "string", "format": "date-time"},
            {"type": "null"}
          ]
        }
      },
      "additionalProperties": false
    },
    "mentalityResult": {
      "type": "object",
      "required": ["band", "evidenceCount"],
      "properties": {
        "band": {"enum": ["emerging", "developing", "consistent", "strong"]},
        "evidenceCount": {"type": "integer", "minimum": 0},
        "ruleIds": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
